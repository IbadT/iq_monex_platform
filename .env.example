# AWS S3 configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET_NAME=your_bucket_name_here

# Elasticsearch configuration
ELASTICSEARCH_NODE=http://localhost:9200
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=changeme

YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_SECRET_KEY=your_secret_key

# Email SMTP Configuration (Timeweb Cloud)
# NOREPLY SMTP (автоматические рассылки)
SMTP_NOREPLY_HOST=smtp.timeweb.ru
SMTP_NOREPLY_PORT=587
SMTP_NOREPLY_USER=noreply@yourdomain.com
SMTP_NOREPLY_PASS=your_password

# SUPPORT SMTP (поддержка и общение)
SMTP_SUPPORT_HOST=smtp.timeweb.ru
SMTP_SUPPORT_PORT=587
SMTP_SUPPORT_USER=support@yourdomain.com
SMTP_SUPPORT_PASS=your_password

# Email settings
EMAIL_NOREPLY_NAME="Your App"
EMAIL_SUPPORT_NAME="Support Team"
SUPPORT_EMAIL=support@yourdomain.com
APP_URL=https://yourapp.com

# Frontend URL для ссылок в email письмах
FRONTEND_URL=http://localhost:5173

# Swagger Basic Auth (опционально)
# Если не заданы, Swagger будет доступен без пароля
SWAGGER_USER=admin
SWAGGER_PASSWORD=secret123