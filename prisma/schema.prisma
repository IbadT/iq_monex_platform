generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "nodeFs"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// model Categories {
//   id        Int      @id @default(autoincrement())
//   name      String
//   createdAt DateTime @default(now())
//   updatedAt DateTime @updatedAt

//   @@map("categories")
// }

model Category {
  id       Int        @id @default(autoincrement())
  name     String
  parentId Int?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  @@index([parentId])
  @@index([name])
}

model Currency {
  id     Int    @id @default(autoincrement())
  symbol String
  code   String @unique
  name   Json // {"ru": "Российский рубль", "en": "Russian Ruble", "kz": "..."}

  @@map("currencies")
}

model UnitMeasurement {
  id   Int  @id @default(autoincrement())
  name Json

  @@map("unit_measurements")
}

model Specification {
  id   Int  @id @default(autoincrement())
  name Json

  @@map("specifications")
}
