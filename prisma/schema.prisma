generator client {
  provider   = "prisma-client"
  output     = "./generated/"
  engineType = "nodeFs"
}

datasource db {
  provider = "postgresql"
}

// PinnedChat не имеет уникального constraint на (userId, chatId) — можно создать дубликаты
// Message не индексирован по createdAt — чаты будут медленно загружаться при сортировке
// Review.content 2000 символов без индекса для full-text search

// ================ USER ================

model User {
  id            String  @id @default(uuid()) @db.Uuid
  email         String  @unique
  name          String
  accountNumber String  @unique
  password      String
  isVerified    Boolean @default(false) @map("is_verified")

  // TODO: пересмотреть реализацию бана
  isBanned  Boolean @default(false) @map("is_banned")
  banReason String? @map("ban_reason")

  // Профиль пользователя
  profile Profile?

  // Рейтинг пользователя (агрегированный)
  rating       Float? @default(0)
  reviewsCount Int    @default(0) @map("reviews_count")

  roleId String @map("role_id") @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id])

  usersChats       UserChat[]
  pinedChats       PinnedChat[]
  chatFiles        ChatFile[]
  message          Message[]         @relation("SentMessages")
  chatParticipants ChatParticipant[]
  listings         Listing[]

  authoredReviews Review[]      @relation("AuthoredReviews")
  receivedReviews Review[]      @relation("ReceivedReviews")
  reviewLikes     ReviewLike[]
  listingLikes    ListingLike[]

  files     File[]
  workers   Worker[]
  locations MapLocation[] @relation("UserLocations")

  subscriptions Subscription[]
  payments      Payment[]
  donations     Donation[]
  slotPackages  SlotPackage[]
  userSlots     UserSlot[]

  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  favorites   Favorite[] @relation("UserFavorites") // Что пользователь добавил в избранное
  favoritedBy Favorite[] @relation("UserFavoritedBy") // Кто добавил этого пользователя

  // Жалобы
  authoredComplaints Complaint[] @relation("ComplaintAuthor") // Жалобы, поданные этим пользователем
  receivedComplaints Complaint[] @relation("UserComplaints") // Жалобы на этого пользователя

  // Активности (многие ко многим через промежуточную таблицу)
  userActivities UserActivity[]
  
  // Promo кампании
  promoCampaignParticipants PromoCampaignParticipant[]

  // Заметки пользователя
  authoredNotes UserNote[] @relation("AuthoredNotes")
  // receivedNotes UserNote[] @relation("ReceivedNotes")

  @@map("users")
}

// ================ PROFILE ================
model Profile {
  id String @id @default(uuid()) @db.Uuid

  userId String @unique @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Тип юридического лица (опционально при регистрации)
  legalEntityTypeId Int?             @map("legal_entity_type_id")
  legalEntityType   LegalEntityType? @relation(fields: [legalEntityTypeId], references: [id])

  // Валюта (обязательная, по умолчанию российский рубль)
  currencyId Int      @map("currency_id")
  currency   Currency @relation(fields: [currencyId], references: [id])

  // Дополнительные поля профиля
  avatarUrl   String? @map("avatar_url")
  phone       String?
  email       String?
  telegram    String?
  siteUrl     String? @map("site_url")
  description String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

// ================ USER ACTIVITIES (MANY-TO-MANY) ================

model UserActivity {
  id         String @id @default(uuid()) @db.Uuid
  userId     String @map("user_id") @db.Uuid
  activityId Int    @map("activity_id")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, activityId])
  @@map("user_activities")
}

model Complaint {
  id            String        @id @default(uuid()) @db.Uuid
  complaintType ComplaintType
  type          String
  text          String

  // Кто подал жалобу
  authorId String @map("author_id") @db.Uuid
  author   User   @relation("ComplaintAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  // На кого подана жалоба (заполняется в зависимости от complaintType)
  listingId    String? @map("listing_id") @db.Uuid
  targetUserId String? @map("target_user_id") @db.Uuid

  listing    Listing? @relation("ListingComplaints", fields: [listingId], references: [id], onDelete: Cascade)
  targetUser User?    @relation("UserComplaints", fields: [targetUserId], references: [id], onDelete: Cascade)

  // Фотографии (только для жалоб на объявления)
  photos File[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([authorId])
  @@index([complaintType, listingId])
  @@index([complaintType, targetUserId])
  @@map("complaints")
}

// ================ WORKERS ================
model Worker {
  id    String @id @default(uuid()) @db.Uuid
  name  String
  phone String
  email String

  isActive Boolean @map("is_active")

  roleId String @map("role_id") @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id])

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([roleId])
  @@index([userId])
  @@map("workers")
}

model Role {
  id   String   @id @default(uuid()) @db.Uuid
  role String   @unique
  code String
  // type RoleType @unique
  type RoleType

  users   User[]
  workers Worker[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([type])
  @@map("roles")
}

// ================ DEFAULT ================

model Category {
  id       Int        @id @default(autoincrement())
  name     String
  parentId Int?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  // categorySpecifications CategorySpecification[]

  // Характеристики для этой категории (любого уровня)
  specifications CategorySpecification[]

  // Объявления в этой категории (разные уровни)
  listingsAsCategory       Listing[] @relation("ListingCategory")
  listingsAsSubcategory    Listing[] @relation("ListingSubcategory")
  listingsAsSubsubcategory Listing[] @relation("ListingSubsubcategory")

  @@index([parentId])
  @@index([name])
  @@index([parentId, name]) // Для поиска подкатегорий в рамках родителя
  @@map("categories")
}

model Currency {
  id     Int    @id @default(autoincrement())
  symbol String
  code   String @unique
  name   Json // {"ru": "Российский рубль", "en": "Russian Ruble", "kz": "..."}

  listing  Listing[]
  profiles Profile[]

  @@map("currencies")
}

model CurrencyRate {
  id      Int      @id @default(autoincrement())
  code    String   @unique @db.VarChar(3) // Код валюты: USD, EUR, CNY
  nominal Int // Номинал: 1, 10, 100, 1000
  rate    Decimal  @db.Decimal(10, 4) // Курс в рублях
  date    DateTime @db.Date // Дата курса

  @@map("currency_rates")
}

model UnitMeasurement {
  id   Int  @id @default(autoincrement())
  name Json

  listing Listing[]

  @@map("unit_measurements")
}

model Specification {
  id                     Int                     @id @default(autoincrement())
  name                   Json
  categorySpecifications CategorySpecification[]
  listingSpecifications  ListingSpecification[]

  @@map("specifications")
}

// ================ CATEGORY SPECIFICATIONS ================

// Связь категории с характеристиками (для любого уровня вложенности)
model CategorySpecification {
  id         Int @id @default(autoincrement())
  categoryId Int @map("category_id")

  specificationId Int     @map("specification_id")
  isRequired      Boolean @default(false) @map("is_required")
  defaultUnitId   Int?    @map("default_unit_id")

  category      Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  specification Specification @relation(fields: [specificationId], references: [id])

  @@unique([categoryId, specificationId])
  @@map("category_specifications")
}

// ================ CHATS ================
model Chat {
  id String @id @default(uuid()) @db.Uuid

  usersChats       UserChat[]
  messages         Message[]
  pinnedChats      PinnedChat[]
  chatParticipants ChatParticipant[]
  chatFiles        ChatFile[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("chats")
}

model PinnedChat {
  id String @id @default(uuid()) @db.Uuid

  userId    String   @map("user_id") @db.Uuid
  chatId    String   @map("chat_id") @db.Uuid
  pinned_at DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  chat Chat @relation(fields: [chatId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("pinned_chats")
}

model UserChat {
  id      String @id @default(uuid()) @db.Uuid
  usersId String @map("user_id") @db.Uuid
  chatsId String @map("chats_id") @db.Uuid

  user User @relation(fields: [usersId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  chat Chat @relation(fields: [chatsId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@unique([usersId, chatsId])
  @@index([usersId, chatsId], map: "users_chats_index_0")
  @@map("users_chats")
}

model ChatParticipant {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  chatId String @map("chat_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  chat Chat @relation(fields: [chatId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at") @db.Timestamp()

  @@unique([userId, chatId])
  @@map("chat_participants")
}

model Message {
  id       String  @id @default(uuid()) @db.Uuid
  senderId String  @map("sender_id") @db.Uuid
  message  String  @db.VarChar(1000)
  isRead   Boolean @default(false) @map("is_read")
  chatId   String  @map("chat_id") @db.Uuid

  sender User @relation("SentMessages", fields: [senderId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  chat   Chat @relation(fields: [chatId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([chatId, createdAt])
  @@map("messages")
}

model ChatFile {
  id           String   @id @default(uuid()) @db.Uuid
  mimeType     String   @map("mime_type") @db.VarChar(100)
  uploadStatus String   @default("pending") @map("upload_status") @db.VarChar(20)
  userId       String   @map("user_id") @db.Uuid
  chatId       String   @map("chat_id") @db.Uuid
  expiresAt    DateTime @default(dbgenerated("CURRENT_DATE + INTERVAL '30 days'")) @map("expires_at") @db.Date
  fileUrl      String   @map("file_url") @db.VarChar(255)

  user User @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  chat Chat @relation(fields: [chatId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("chat_files")
}

// ================ LISTINGS ================
model Listing {
  id String @id @default(uuid()) @db.Uuid

  userId        String @map("user_id") @db.Uuid
  categoryId    Int?   @map("category_id")
  subcategoryId Int?   @map("subcategory_id")
  subsubcategoryId Int? @map("subsubcategory_id")

  // Контактные данные для объявления
  contactId   String? @map("contact_id") @db.Uuid
  contactType String? @map("contact_type") // "USER" или "WORKER"

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Связи с категориями разных уровней
  category       Category? @relation("ListingCategory", fields: [categoryId], references: [id])
  subcategory    Category? @relation("ListingSubcategory", fields: [subcategoryId], references: [id])
  subsubcategory Category? @relation("ListingSubsubcategory", fields: [subsubcategoryId], references: [id])

  favorites Favorite[]
  reviews   Review[]
  likes     ListingLike[]

  // Рейтинг объявления (агрегированный)
  rating       Float? @default(0)
  reviewsCount Int    @default(0) @map("reviews_count")

  title String? @db.VarChar(255)

  // Для шаблонов
  description String? @db.VarChar(3000)

  // ===== СТАТУС И ЖИЗНЕННЫЙ ЦИКЛ =====
  status ListingStatus @default(DRAFT)

  // Черновик: удаляется после публикации
  // Шаблон: никогда не удаляется автоматически
  // Архив: авто-удаление через 60 дней

  // ===== ЦЕНА =====
  // Для шаблонов — цена может быть null (заполнится позже)
  price      Decimal? @db.Decimal(15, 2)
  currencyId Int?     @map("currency_id")

  currency Currency? @relation(fields: [currencyId], references: [id])

  // Единица измерения цены (за штуку, за кг, за м²...)
  priceUnitId Int?             @map("price_unit_id")
  priceUnit   UnitMeasurement? @relation(fields: [priceUnitId], references: [id])

  // ===== СОСТОЯНИЕ =====
  condition ListingCondition?

  // ===== СЧЁТЧИКИ =====
  viewsCount     Int @default(0) @map("views_count")
  favoritesCount Int @default(0) @map("favorites_count")
  likesCount     Int @default(0) @map("likes_count")

  // Для оптимистической блокировки(лайки)
  version Int @default(0)

  // TODO: пересмотреть
  // TODO: добавить причину в коде и проверку, что оно ARCHIVED
  // архивация админом, если объявление нарушает правила
  archivedReason String? @map("archived_reason") @db.VarChar(1000)

  // ===== ДАТЫ =====
  publishedAt  DateTime? @map("published_at") // Когда опубликовано
  archivedAt   DateTime? @map("archived_at") // Когда отправлено в архив
  autoDeleteAt DateTime? @map("auto_delete_at") // Авто-удаление архива (60 дней)

  // Для шаблонов — когда последний раз использовался
  lastUsedAt DateTime? @map("last_used_at")

  // ===== RELATIONS =====
  files          File[]
  locations      MapLocation[]          @relation("ListingLocations")
  specifications ListingSpecification[]

  listingSlot ListingSlot?

  // Жалобы на объявление
  complaints Complaint[] @relation("ListingComplaints")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Индексы для производительности
  @@index([userId, status])
  @@index([status, autoDeleteAt])
  @@index([subcategoryId, status, publishedAt])
  @@index([status, lastUsedAt])
  // Дополнительные индексы для поиска и фильтрации
  @@index([status, createdAt]) // Для сортировки по дате в рамках статуса
  @@index([subcategoryId, status]) // Для фильтрации по подкатегории и статусу
  @@index([condition, status]) // Для фильтрации по состоянию и статусу
  @@index([price, status]) // Для фильтрации по цене и статусу
  @@index([status, condition, subcategoryId]) // Композитный индекс для популярных фильтров
  @@index([createdAt]) // Для общей сортировки по дате
  @@map("listings")
}

// ================ LISTING SPECIFICATIONS ================

model ListingSpecification {
  id        String @id @default(uuid()) @db.Uuid
  listingId String @map("listing_id") @db.Uuid

  specificationId Int    @map("specification_id")
  value           String

  unitId     Int?    @map("unit_id")
  isRequired Boolean @default(true) @map("is_required")

  listing       Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  specification Specification @relation(fields: [specificationId], references: [id])

  @@unique([listingId, specificationId])
  @@map("listing_specifications")
}

// ================ LOCATIONS (отдельная таблица) ================

model MapLocation {
  id String @id @default(uuid()) @db.Uuid

  // Owner может быть либо пользователем, либо объявлением
  userId String? @map("user_id") @db.Uuid
  user   User?   @relation("UserLocations", fields: [userId], references: [id], onDelete: Cascade)

  listingId String?  @map("listing_id") @db.Uuid
  listing   Listing? @relation("ListingLocations", fields: [listingId], references: [id], onDelete: Cascade)

  type MapLocationType

  // Адрес для отображения
  address String

  country String

  city String

  latitude  Decimal @db.Decimal(10, 8)
  longitude Decimal @db.Decimal(11, 8)

  // Гео-индекс для поиска "рядом со мной"
  geoHash String @map("geo_hash") // для быстрого поиска по радиусу

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([listingId])
  @@index([latitude, longitude])
  @@index([geoHash])
  @@map("map_locations")
}

// ================ FILES ================
model File {
  id String @id @default(uuid()) @db.Uuid

  // Кому принадлежит файл
  ownerType FileOwnerType @map("owner_type")
  // ownerId   String        @map("owner_id") @db.Uuid // userId или listingId

  // S3
  s3Key    String @map("s3_key")
  s3Bucket String @map("s3_bucket")
  url      String

  // Метаданные
  fileType String @map("file_type") // image/jpeg, application/pdf
  fileName String @map("file_name")
  fileSize Int    @map("file_size")

  // Тип файла
  kind FileKind

  // Для аватаров и фото - порядок/основная
  isPrimary Boolean @default(false) @map("is_primary")
  sortOrder Int     @default(0) @map("sort_order")

  // Статус
  uploadStatus String @default("pending") @map("upload_status") // pending, completed, failed

  // для временных файлов
  expiresAt DateTime? @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId      String? @map("user_id") @db.Uuid
  listingId   String? @map("listing_id") @db.Uuid
  complaintId String? @map("complaint_id") @db.Uuid

  // Relations (опциональные, т.к. ownerId универсальный)
  user      User?      @relation(fields: [userId], references: [id], map: "file_user_fk", onDelete: Cascade)
  listing   Listing?   @relation(fields: [listingId], references: [id], map: "file_listing_fk", onDelete: Cascade)
  complaint Complaint? @relation(fields: [complaintId], references: [id], map: "file_complaint_fk", onDelete: Cascade)

  // TODO: один аватар у одного ползователя
  // @@unique([userId, kind])
  @@index([userId])
  @@index([listingId])
  @@index([complaintId])
  @@index([ownerType, userId])
  @@index([ownerType, listingId])
  @@index([ownerType, complaintId])
  @@index([ownerType, userId, kind])
  @@index([ownerType, listingId, kind])
  @@index([ownerType, complaintId, kind])
  @@index([uploadStatus, expiresAt])
  @@index([listingId, kind, sortOrder]) // Для фото объявлений с сортировкой
  @@map("files")
}

// ================ FAVORITES ================

model Favorite {
  id     String       @id @default(uuid()) @db.Uuid
  // ID пользователя, который добавил в избранное (владелец записи)
  userId String       @map("user_id") @db.Uuid
  type   FavoriteType

  // В зависимости от type, одно из полей должно быть заполнено
  // ID объявления (Listing), добавленного в избранное
  listingId String? @map("listing_id") @db.Uuid

  // ID пользователя (User), добавленного в избранное
  targetUserId String? @map("target_user_id") @db.Uuid

  user       User     @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)
  listing    Listing? @relation(fields: [listingId], references: [id], onDelete: Cascade)
  targetUser User?    @relation("UserFavoritedBy", fields: [targetUserId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, type, listingId])
  @@unique([userId, type, targetUserId])
  @@index([userId])
  @@index([listingId])
  @@index([targetUserId])
  @@map("favorites")
}

// ================ REVIEWS (комментарии с рейтингом) ================

model Review {
  id String @id @default(uuid()) @db.Uuid

  // Кто оставил отзыв
  authorId String @map("author_id") @db.Uuid

  // На какое объявление (или на какого пользователя — гибкость)
  targetType   ReviewTargetType @map("target_type") // LISTING или USER
  listingId    String?          @map("listing_id") @db.Uuid
  targetUserId String?          @map("target_user_id") @db.Uuid

  // Содержание
  rating  Int // 1-5 звёзд
  title   String? @db.VarChar(255) // Заголовок отзыва
  content String  @db.VarChar(2000) // Текст отзыва

  // Модерация
  status ReviewStatus @default(PENDING) // PENDING, APPROVED, REJECTED

  // Счётчики
  likesCount   Int @default(0) @map("likes_count")
  reportsCount Int @default(0) @map("reports_count")

  // Ответ владельца (опционально)
  replyContent  String?   @map("reply_content") @db.VarChar(1000)
  replyAt       DateTime? @map("reply_at")
  replyAuthorId String?   @map("reply_author_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  author     User         @relation("AuthoredReviews", fields: [authorId], references: [id], onDelete: Cascade)
  listing    Listing?     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  targetUser User?        @relation("ReceivedReviews", fields: [targetUserId], references: [id], onDelete: Cascade)
  files      ReviewFile[]
  likes      ReviewLike[]

  @@index([authorId])
  @@index([listingId, status]) // Для поиска approved отзывов
  @@index([targetUserId, status])
  @@map("reviews")
}

// Файлы к отзыву (фото товара, скриншоты)
model ReviewFile {
  id       String @id @default(uuid()) @db.Uuid
  reviewId String @map("review_id") @db.Uuid

  // S3
  s3Key    String @map("s3_key")
  s3Bucket String @map("s3_bucket")
  url      String

  fileType String @map("file_type")
  fileName String @map("file_name")
  fileSize Int    @map("file_size")

  sortOrder Int @default(0) @map("sort_order")

  createdAt DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_files")
}

// ================ LISTING LIKES ================
model ListingLike {
  id        String @id @default(uuid()) @db.Uuid
  listingId String @map("listing_id") @db.Uuid
  userId    String @map("user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([listingId, userId]) // Один пользователь — один лайк на объявление
  @@index([listingId])
  @@index([userId])
  @@map("listing_likes")
}

// Лайки к отзывам (чтобы отслеживать полезность)
model ReviewLike {
  id       String @id @default(uuid()) @db.Uuid
  reviewId String @map("review_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@map("review_likes")
}

// ================ TARIFFS ================

model Tariff {
  id           String     @id @default(uuid()) @db.Uuid
  code         TariffCode
  name         String
  description  String
  baseSlots    Int        @map("base_slots") // Количество слотов при покупке
  baseDays     Int        @map("base_days") // Базовый срок действия (дней)
  maxTotalDays Int        @map("max_total_days") // Максимальный срок (для продлений)
  isExtendable Boolean    @map("is_extendable") // Можно ли продлевать
  isActive     Boolean    @default(true) @map("is_active")
  price        Decimal    @db.Decimal(12, 2) // Цена (в базовой валюте)
  currencyCode String     @map("currency_code") // ISO код валюты (BYN, USD, EUR)

  subscriptions Subscription[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tariffs")
}

// ================ SUBSCRIPTIONS ================

model Subscription {
  id       String @id @default(uuid()) @db.Uuid
  userId   String @map("user_id") @db.Uuid
  tariffId String @map("tariff_id") @db.Uuid

  isActive   Boolean @default(true) @map("is_active")
  // Общее количество слотов по этой подписке (для истории)
  totalSlots Int     @map("total_slots")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tariff Tariff @relation(fields: [tariffId], references: [id])

  periods   SubscriptionPeriod[]
  userSlots UserSlot[] // Слоты, созданные этой подпиской
  participants PromoCampaignParticipant[] // Участники акций с этой подпиской

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, isActive])
  @@map("subscriptions")
}




// ================ PROMO CAMPAIGNS ================

enum PromoCampaignStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED

  @@map("promo_campaign_status")
}

enum PromoParticipantStatus {
  PENDING
  IN_PROGRESS
  ELIGIBLE
  FAILED
  COMPLETED
  CANCELED

  @@map("promo_participant_status")
}

model PromoCampaign {
  id                    String                @id @default(uuid()) @db.Uuid
  code                  String                @unique
  name                  String
  status                PromoCampaignStatus   @default(ACTIVE)
  maxParticipants       Int
  currentParticipants   Int                   @default(0)

  initialFreeDays       Int                  @map("initial_free_days")
  subsequentDiscount    Int                  @map("subsequent_discount")
  subsequentDays        Int                  @map("subsequent_days")

  requiredActiveListings Int                  @default(10) @map("required_active_listings")
  requiredDays          Int                  @default(7) @map("required_days")

  startAt DateTime      @default(now()) @map("start_at")
  endAt   DateTime?     @map("end_at")

  // Флаг блокировки кампании (true когда достигнут лимит участников)
  isLocked  Boolean     @default(false) @map("is_locked")

  participants PromoCampaignParticipant[]

  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@index([status])
  @@map("promo_campaigns")
}

model PromoCampaignParticipant {
  id                String                @id @default(uuid()) @db.Uuid
  campaignId        String                @map("campaign_id") @db.Uuid
  userId            String                @map("user_id") @db.Uuid

  status            PromoParticipantStatus @default(PENDING)

  joinedAt          DateTime              @default(now()) @map("joined_at")
  conditionReachedAt DateTime?            @map("condition_reached_at")
  conditionLostAt    DateTime?            @map("condition_lost_at")

  // Флаг что пользователь получил бесплатный период
  freePeriodGranted  Boolean  @default(false) @map("free_period_granted")
  // Флаг что пользователь использовал скидку 50% на второй год
  discountUsed       Boolean  @default(false) @map("discount_used")
  // Дата когда скидка стала доступной
  discountAvailableAt DateTime? @map("discount_available_at")
  // Статус вылета из акции (не смог выполнить условия)
  droppedOut         Boolean  @default(false) @map("dropped_out")
  droppedOutAt       DateTime? @map("dropped_out_at")
  // Причина вылета
  dropReason         String?  @map("drop_reason")

  campaign          PromoCampaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  subscriptionId    String?               @map("subscription_id") @db.Uuid
  subscription      Subscription?         @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([campaignId, userId])
  @@index([userId])
  @@index([campaignId])
  @@map("promo_campaign_participants")
}





model SubscriptionPeriod {
  id             String @id @default(uuid()) @db.Uuid
  subscriptionId String @map("subscription_id") @db.Uuid

  days    Int // Сколько дней добавлено
  startAt DateTime @map("start_at")
  endAt   DateTime @map("end_at")

  // Ссылка на платёж, которым оплачен этот период
  paymentId String? @map("payment_id") @db.Uuid

  // Процент скидки (0 = без скидки, 50 = 50% скидка, 100 = бесплатно)
  discountPercent Int     @default(0) @map("discount_percent")
  // Статус периода: FREE = бесплатный период, DISCOUNTED = со скидкой, PAID = обычная цена
  periodType      String  @default("PAID") @map("period_type") // FREE, DISCOUNTED, PAID

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([subscriptionId, endAt])
  @@map("subscription_periods")
}

// ================ PAYMENTS ================

model Payment {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  amount   Decimal       @db.Decimal(12, 2)
  currency String // BYN, USD, EUR
  status   PaymentStatus @default(PENDING)

  // Данные от платёжной системы
  externalId  String @map("external_id") @db.VarChar(100)
  provider    String // Название платёжной системы (yookassa, stripe, etc)
  description String

  // Для связывания с invoice/счётом
  invoiceId String? @map("invoice_id") @db.VarChar(50)

  // Дополнительные данные от провайдера
  metadata Json? // @db.JsonB

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items PaymentItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId, status])
  @@index([externalId])
  @@index([status, createdAt])
  @@map("payments")
}

model PaymentItem {
  id        String @id @default(uuid()) @db.Uuid
  paymentId String @map("payment_id") @db.Uuid

  itemType  PaymentItemType @map("item_type")
  // ID сущности в зависимости от типа:
  // - SUBSCRIPTION → subscription.id
  // - SLOT_PACKAGE → slot_package.id  
  // - DONATION → donation.id
  itemId    String          @db.Uuid
  itemIdStr String?         @map("item_id_str") // Для совместимости если нужно

  quantity  Int     @default(1)
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)

  // Описание позиции (название тарифа/пакета)
  description String

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([paymentId])
  @@index([itemType, itemId])
  @@map("payment_items")
}

// ================ DONATIONS ================

enum DonationStatus {
  PENDING
  COMPLETED
  CANCELED
}

model Donation {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  amount   Decimal @db.Decimal(12, 2)
  currency String // BYN, USD, EUR

  comment String?

  // Статус доната
  status DonationStatus @default(PENDING)

  // Ссылка на платёж
  paymentId String? @map("payment_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("donations")
}

// ================ SLOT PACKAGES ================

model SlotPackage {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  slots Int // Количество купленных слотов
  price Decimal @db.Decimal(12, 2) // Цена покупки (для аналитики)

  // Срок действия слотов пакета (обычно бессрочно или длительный)
  expiresAt DateTime @map("expires_at")
  isActive  Boolean  @default(true) @map("is_active")

  // Ссылка на платёж
  paymentId String? @map("payment_id") @db.Uuid

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  userSlots UserSlot[] // Созданные этим пакетом слоты

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isActive])
  @@map("slot_packages")
}

// ================ USER SLOTS ================

model UserSlot {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  slotIndex Int @map("slot_index") // 1, 2, 3... для отображения пользователю

  sourceType SlotSource @map("source_type")
  // ID подписки или пакета
  sourceId   String     @map("source_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at") // Когда слот истекает (независимо от использования)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  listingSlot    ListingSlot? // Текущее использование слота
  slotPackage    SlotPackage?  @relation(fields: [slotPackageId], references: [id])
  slotPackageId  String?       @db.Uuid
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id])
  subscriptionId String?       @db.Uuid

  @@unique([userId, slotIndex])
  @@index([userId, expiresAt])
  @@index([sourceType, sourceId])
  @@map("user_slots")
}

// ================ LISTING SLOTS ================

model ListingSlot {
  id        String @id @default(uuid()) @db.Uuid
  listingId String @unique @map("listing_id") @db.Uuid // 1:1 с Listing

  userSlotId String @unique @map("user_slot_id") @db.Uuid // Какой слот используется

  assignedAt DateTime  @map("assigned_at")
  releasedAt DateTime? @map("released_at") // Когда слот освобождён

  // Причина освобождения (для аналитики)
  releaseReason String? @map("release_reason") // ARCHIVED, DELETED, REPUBLISHED

  listing  Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userSlot UserSlot @relation(fields: [userSlotId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userSlotId, releasedAt])
  @@map("listing_slots")
}

// ================ LEGAL ENTITY TYPES ================

model LegalEntityType {
  id   Int  @id @default(autoincrement())
  data Json

  profiles Profile[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("legal_entity_types")
}

// ================ ACTIVITIES ================
model Activity {
  id   Int    @id @default(autoincrement())
  name String @unique

  userActivities UserActivity[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("activities")
}

// ================ USER SUGGESTIONS ================
model UserSuggestion {
  id   Int    @id @default(autoincrement())
  text String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_suggestions")
}

// ================ ENUMS ================
enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED

  @@map("payment_status")
}

enum SlotSource {
  SUBSCRIPTION
  SLOT_PACKAGE

  @@map("slot_cource")
}

enum PaymentItemType {
  SUBSCRIPTION
  SLOT_PACKAGE
  DONATION

  @@map("payment_item_type")
}

enum TariffCode {
  BASE // 3 слота, 30 дней
  MAIN // 10 слотов, 60 дней  
  PREMIUM // 30 слотов, 90 дней, возможность продления
  ADDITIONAL_PACKAGE // Дополнительный пакет слотов

  @@map("tariff_code")
}

enum ListingStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  TEMPLATE

  @@map("listing_status")
}

enum ListingCondition {
  NEW
  USED

  @@map("listing_condition")
}

enum MapLocationType {
  OFFICE
  WAREHOUSE

  @@map("map_location_type")
}

enum FileOwnerType {
  USER // Файлы пользователя
  LISTING // Файлы объявления
  COMPLAINT // Файлы жалоб

  @@map("file_owner_type")
}

enum FileKind {
  AVATAR // Аватар пользователя
  PHOTO // Фото объявления (макс 10)
  DOCUMENT // Документ (макс 5)
  COMPLAINT_PHOTO // Фото к жалобе

  @@map("file_kind")
}

enum ReviewTargetType {
  LISTING
  USER

  @@map("review_target_type")
}

enum ReviewStatus {
  PENDING // На модерации
  APPROVED // Опубликован
  REJECTED // Отклонён

  @@map("review_status")
}

enum RoleType {
  WORKER
  USER
  ADMIN
  SUPER_ADMIN

  @@map("role_types")
}

enum FavoriteType {
  LISTING
  USER
}

enum ComplaintType {
  LISTING
  USER
}

// ================ USER NOTES ================
// Заметки пользователей о других пользователях и объявлениях
model UserNote {
  id        String   @id @default(uuid()) @db.Uuid
  
  // Кто создал заметку
  authorId  String   @map("author_id") @db.Uuid
  author    User     @relation("AuthoredNotes", fields: [authorId], references: [id], onDelete: Cascade)
  
  // Тип цели заметки
  targetType UserNoteTargetType @map("target_type")
  
  // ID цели (пользователь или объявление)
  targetUserId  String? @map("target_user_id") @db.Uuid
  targetListingId String? @map("target_listing_id") @db.Uuid
  
  // Текст заметки (макс 100 символов)
  content   String   @db.VarChar(100)
  
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  
  // Один пользователь может иметь только одну заметку на одну цель
  @@unique([authorId, targetType, targetUserId], name: "unique_user_note_per_user")
  @@unique([authorId, targetType, targetListingId], name: "unique_user_note_per_listing")
  
  @@index([authorId])
  @@index([targetUserId])
  @@index([targetListingId])
  @@map("user_notes")
}

enum UserNoteTargetType {
  USER
  LISTING
}

