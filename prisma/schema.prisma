generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "nodeFs"
}

datasource db {
  provider = "postgresql"
}

// ================ USER ================

model User {
  id       String @id @default(uuid()) @db.Uuid
  email    String @unique
  name     String
  password String

  usersChats       UserChat[]
  pinedChats       PinnedChat[]
  chatFiles        ChatFile[]
  message          Message[]         @relation("SentMessages")
  chatParticipants ChatParticipant[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

// ================ DEFAULT ================

model Category {
  id       Int        @id @default(autoincrement())
  name     String
  parentId Int?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  @@index([parentId])
  @@index([name])
}

model Currency {
  id     Int    @id @default(autoincrement())
  symbol String
  code   String @unique
  name   Json // {"ru": "Российский рубль", "en": "Russian Ruble", "kz": "..."}

  @@map("currencies")
}

model UnitMeasurement {
  id   Int  @id @default(autoincrement())
  name Json

  @@map("unit_measurements")
}

model Specification {
  id   Int  @id @default(autoincrement())
  name Json

  @@map("specifications")
}

// ================ CHATS ================
model Chat {
  id String @id @default(uuid()) @db.Uuid

  usersChats       UserChat[]
  messages         Message[]
  pinnedChats      PinnedChat[]
  chatParticipants ChatParticipant[]
  chatFiles        ChatFile[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("chats")
}

model PinnedChat {
  id String @id @default(uuid()) @db.Uuid

  userId    String   @map("user_id") @db.Uuid
  chatId    String   @map("chat_id") @db.Uuid
  pinned_at DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  chat Chat @relation(fields: [chatId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@map("pinned_chats")
}

model UserChat {
  id      String @id @default(uuid()) @db.Uuid
  usersId String @map("userd_id") @db.Uuid
  chatsId String @map("chats_id") @db.Uuid

  user User @relation(fields: [usersId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  chat Chat @relation(fields: [chatsId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  @@unique([usersId, chatsId])
  @@index([usersId, chatsId], map: "users_chats_index_0")
  @@map("users_chats")
}

model ChatParticipant {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid
  chatId String @map("chat_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  chat Chat @relation(fields: [chatId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at") @db.Timestamp()

  @@map("chat_participants")
}

model Message {
  id       String  @id @default(uuid()) @db.Uuid
  senderId String  @map("sender_id") @db.Uuid
  message  String  @db.VarChar(1000)
  isRead   Boolean @default(false) @map("is_read")
  chatId   String  @map("chat_id") @db.Uuid

  sender User @relation("SentMessages", fields: [senderId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  chat   Chat @relation(fields: [chatId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("messages")
}

model ChatFile {
  id           String   @id @default(uuid()) @db.Uuid
  mimeType     String   @map("mime_type") @db.VarChar(100)
  uploadStatus String   @default("pending") @map("upload_status") @db.VarChar(20)
  userId       String   @map("user_id") @db.Uuid
  chatId       String   @map("chat_id") @db.Uuid
  expiresAt    DateTime @default(dbgenerated("CURRENT_DATE + INTERVAL '30 days'")) @map("expires_at") @db.Date
  fileUrl      String   @map("file_url") @db.VarChar(255)

  user User @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  chat Chat @relation(fields: [chatId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("chat_files")
}

// ================ LISTINGS ================
model Listing {
  id   String @id @default(uuid()) @db.Uuid
  name String

  subcategoryId String

  price Int

  // связь с Currency
  price_symbol String
  price_unit   String
  condition    String // новой или б/у

  photos String[] // максимум 10
  files  String[] // максимум 5

  specifications String[] // тут пользователь будет выбирать характеристику и Specifications таблицы и добавлять к этому name свой value для объявления

  description String @db.VarChar(3000)

  // я думаю, что нужна новая таблица для maps где будут храниться координаты(метрики для карты)
  maps String[] // должно передаваться (тип(например офис, склад и тд), и координаты latitude, longtitude)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("listings")
}
